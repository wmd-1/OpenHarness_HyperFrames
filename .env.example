# ============================================================================
# OpenHarness 环境变量配置
# ============================================================================
# 使用方法：复制本文件为 .env 并填入实际值
#   cp .env.example .env
# ============================================================================

# ---- LLM API Keys（至少配置一个）----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- 可选 API Keys ----
# OPENROUTER_API_KEY=
# ELEVENLABS_API_KEY=
# HEYGEN_API_KEY=

# ---- QwenTTS (本地 TTS 服务) ----
# 设置后自动启用 qwentts provider（优先级最高）
# QWENTTS_URL=http://localhost:8091
# QWENTTS_MODE=speech          # speech 或 chat
# QWENTTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
# QWENTTS_VOICE=vivian
# QWENTTS_INSTRUCTIONS=         # 情感/风格指令，如 "Speak with great enthusiasm"

# ---- 镜像版本标签 ----
OH_VERSION_HYPERFRAMES_VERSION=v0.1.9_v0.7.20_v1.3_v2.0

# ---- 构建参数（通常不需要修改）----
# PYTHON_VERSION=3.11
# UV_VERSION=0.7.3

# ---- 前端 API Key（浏览器端 localStorage，非本文件配置）----
# 仅当部署端设置了上方 API_KEY（启用 X-API-Key 鉴权）时需要：
# 访问前端页面，在侧栏「API Key」卡片填入该 Key 并保存。
# 前端会自动为请求携带 X-API-Key（SSE / 文件通过 ?api_key= 参数）。

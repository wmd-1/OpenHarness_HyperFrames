      /* Neural node */
      .node { position: absolute; border-radius: 50%; pointer-events: none; }
      .edge { position: absolute; pointer-events: none; }

      /* Token blocks */
      .token-block {
        display: inline-block; border-radius: 4px; margin: 3px;
        font-family: 'JetBrains Mono', monospace; font-size: 20px;
        padding: 6px 10px; font-weight: 500;
      }

      /* Card */

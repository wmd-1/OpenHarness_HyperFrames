        background: rgba(108,140,255,0.08); border: 1px solid rgba(108,140,255,0.15);
        border-radius: 16px; padding: 28px 32px; backdrop-filter: blur(4px);
      }

      /* Attention heatmap */
      .attn-cell {
        border-radius: 2px; position: absolute;
      }

      /* Data bar */
      .data-bar {
        height: 12px; border-radius: 6px;
        background: linear-gradient(90deg, #6c8cff, #00d4aa);
      }

      /* Pulse ring */
      .pulse-ring {
        position: absolute; border: 2px solid rgba(108,140,255,0.3);
        border-radius: 50%; pointer-events: none;
      }
    </style>

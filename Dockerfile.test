# Test image: adds pytest + test deps on top of oh-e2e:latest
# Build: docker build -t oh-e2e-test:latest -f Dockerfile.test .
# Run:   docker run --rm -v $(pwd)/service:/opt/oh-service oh-e2e-test:latest
FROM oh-e2e:latest

RUN /root/.openharness-venv/bin/pip install --no-cache-dir \
    pytest pytest-asyncio httpx aiosqlite fakeredis

WORKDIR /opt/oh-service

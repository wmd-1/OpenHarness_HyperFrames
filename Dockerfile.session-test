# session-service test image.
#
# Base: oh-e2e-test:latest — ships the full `oh` CLI venv, headless chrome,
# Node, ffmpeg, OpenHarness skills. We:
#   1. install the session-service runtime + test deps into the existing venv,
#   2. overlay the session-service code (the code under test),
#   3. install the oh-backend-stub as a standalone binary (offline protocol tests),
#   4. expose a pytest entrypoint.
#
# Build:
#   docker build -t oh-session-test:latest -f Dockerfile.session-test .
# Run tests:
#   docker run --rm oh-session-test:latest
# Contract smoke (real oh):
#   docker run --rm -e OH_OH_BIN=/root/.local/bin/oh oh-session-test:latest \
#       python /opt/oh-session-service/scripts/contract_smoke.py

FROM oh-e2e-test:latest

USER root

# --- session-service runtime + test deps (into the image's existing venv) ----
# pip skips already-satisfied packages, so this is cheap on oh-e2e-test which
# already carries fastapi/sqlalchemy/redis/structlog/prometheus-client/etc.
RUN /root/.openharness-venv/bin/pip install --no-cache-dir \
    "fastapi>=0.115,<0.116" \
    "uvicorn[standard]>=0.32,<0.33" \
    "sqlalchemy[asyncio]>=2.0,<3" \
    "asyncpg>=0.30,<1" \
    "psycopg[binary]>=3.2,<4" \
    "alembic>=1.14,<2" \
    "redis>=5.2,<6" \
    "pydantic-settings>=2.6,<3" \
    "sse-starlette>=2.1,<3" \
    "python-multipart>=0.0.9" \
    "websockets>=13,<14" \
    "boto3>=1.34,<2" "botocore>=1.34,<2" \
    "prometheus-client>=0.20,<1" \
    "structlog>=24,<25" \
    "psutil>=6,<7" \
    "opentelemetry-api>=1.27,<1.28" \
    "opentelemetry-sdk>=1.27,<1.28" \
    "opentelemetry-exporter-otlp>=1.27,<1.28" \
    "opentelemetry-instrumentation-fastapi==0.48b0" \
    "opentelemetry-instrumentation-sqlalchemy==0.48b0" \
    "opentelemetry-instrumentation-redis==0.48b0" \
    "httpx>=0.27,<0.28" \
    "pytest>=8" "pytest-asyncio>=0.23" "pytest-cov>=5" \
    "aiosqlite>=0.20" "fakeredis>=2.20"

# --- overlay the session-service code (the code under test) ------------------
COPY session-service /opt/oh-session-service

# --- oh backend stub as a standalone binary (offline protocol tests) ---------
COPY session-service/scripts/oh_backend_stub.py /usr/local/bin/oh-backend-stub
RUN chmod +x /usr/local/bin/oh-backend-stub

# Default: the stub speaks the OHJSON protocol without an LLM API key.
ENV OH_OH_BIN=/usr/local/bin/oh-backend-stub \
    PYTHONPATH=/app/src:/opt/oh-session-service \
    OH_WORKSPACE_ROOT=/workspaces \
    OH_VIDEO_DIR=/var/openharness/videos

WORKDIR /opt/oh-session-service
ENTRYPOINT ["/root/.openharness-venv/bin/python", "-m", "pytest"]
CMD ["-q"]
